generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  body      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
